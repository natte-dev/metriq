# Banco de dados MySQL
# Desenvolvimento local (com docker-compose):
DATABASE_URL="mysql://metriq:metriq@localhost:3306/metriq"

# Senha do gerente - hash bcrypt (rounds=10)
# Gere com: node -e "const b=require('bcryptjs'); console.log(b.hashSync('SUA_SENHA',10));"
MANAGER_PASSWORD_HASH="$2b$10$..."

# Produção (EasyPanel - ajustar para sua VPS MySQL):
# DATABASE_URL="mysql://usuario:senha@IP_VPS_MYSQL:3306/metriq"
